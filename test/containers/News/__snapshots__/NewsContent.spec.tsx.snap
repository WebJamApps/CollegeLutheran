// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`NewsContent > renders the news page 1`] = `
<div>
  <div
    class="page-content"
  >
    <div>
      <div>
        <p>
          There are currently no pdfs links to display
        </p>
      </div>
      <p
        style="font-size: 4pt; margin: 0px;"
      >
         
      </p>
      <hr
        style="margin: 0px;"
      />
      <div
        style="margin: auto; text-align: center;"
      >
        <a
          class="signup-link"
          href="https://visitor.r20.constantcontact.com/manage/optin?v=001cd950f6ed99253e212302d6c939739"
          rel="noopener noreferrer"
          target="_blank"
        >
          Sign Up for Email Updates
        </a>
      </div>
    </div>
    <div
      class="editNewsDialog"
    >
      <div>
        Edit News
      </div>
      <div
        sx="[object Object]"
      >
        <input
          class="url"
          label="* URL"
          sx="[object Object]"
          type="text"
          value=""
        />
        <input
          class="title"
          label="* Title"
          sx="[object Object]"
          type="text"
          value=""
        />
        <div>
          <div
            control="[object Object]"
            label="Show as Worship Bulletin"
          />
        </div>
      </div>
      <div>
        <button
          class="updateNewsButton"
          disabled=""
          variant="contained"
        >
          Update
        </button>
        <button
          class="deleteNewsButton"
          style="background-color: red; color: white;"
        >
          Delete
        </button>
        <button
          class="cancelNewsButton"
        >
          Cancel
        </button>
      </div>
    </div>
    <div
      style="text-align: center; padding: 30px 24px 0px;"
    >
      <a
        href="http://www.elca.org/"
        rel="noopener noreferrer"
        target="_blank"
      >
        <img
          alt="ELCA LOGO"
          id="elcaLogo"
          src="/elca-logo.png"
          style="display: block; width: 100%; max-width: 500px; height: auto; margin: 0px auto;"
        />
      </a>
    </div>
  </div>
</div>
`;
