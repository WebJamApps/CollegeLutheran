      </div>
      <div>
        <button
          class="updatePicButton"
          disabled=""
          variant="contained"
        >
          Update
        </button>
        <button
          class="deletePicButton"
          sx="[object Object]"
        >
          Delete
        </button>
        <button
          class="cancelPicButton"
        >
          Cancel
        </button>
      </div>
    </div>
  </div>
</div>
`;
